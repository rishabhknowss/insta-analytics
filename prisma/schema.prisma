generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id             String    @id
  username       String?
  accessToken    String
  tokenExpiresAt Int?
  createdAt      DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())

  reels   Reel[]
  posters Poster[]

  @@map("accounts")
}

model Reel {
  id           String    @id
  accountId    String
  caption      String?
  permalink    String?
  thumbnailUrl String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())

  account    Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dailyStats ReelDailyStat[]

  @@map("reels")
}

model ReelDailyStat {
  id        Int      @id @default(autoincrement())
  reelId    String
  date      DateTime @db.Date
  views     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@unique([reelId, date])
  @@map("reel_daily_stats")
}

enum PaidStatus {
  UNPAID
  PARTIAL
  PAID
}

enum Manager {
  ROHIT
  UJJWAL
  RISHABH
}

model Poster {
  id             Int        @id @default(autoincrement())
  telegramChatId BigInt     @unique
  accountId      String?
  instagramLink  String
  channelName    String
  groupLink      String     @default("")
  managedBy      Manager    @default(RISHABH)
  paidStatus     PaidStatus @default(UNPAID)
  monthlyRate    Int        @default(1500)
  totalPaid      Int        @default(0)
  createdAt      DateTime   @default(now())
  disabled       Boolean    @default(false)
  updatedAt      DateTime   @updatedAt

  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@map("posters")
}

model Payment {
  id        Int      @id @default(autoincrement())
  posterId  Int
  amount    Int
  note      String   @default("")
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  poster Poster @relation(fields: [posterId], references: [id], onDelete: Cascade)

  @@map("payments")
}
